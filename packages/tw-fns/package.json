{
  "name": "tw-fns",
  "type": "module",
  "version": "0.0.5",
  "private": false,
  "description": "A js/ts tailwindcss library implemented using pure functions",
  "files": [
    "dist",
    "base.css"
  ],
  "scripts": {
    "g": "node ./scripts/generate.ts",
    "build": "rimraf dist && tsc -p tsconfig.build.json"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:anuoua/tw-fns.git"
  },
  "exports": {
    "./tools/*": "./dist/tools/*.js",
    "./utilities/*": "./dist/utilities/*.js",
    "./utilities-arbitrary/*": "./dist/utilities-arbitrary/*.js",
    "./wraps/*": "./dist/wraps/*.js",
    "./wraps-arbitrary/*": "./dist/wraps-arbitrary/*.js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^25.2.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zx": "^8.8.5"
  },
  "packageManager": "pnpm@10.23.0"
}
